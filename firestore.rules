rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // L'app legge/scrive solo clubs/laurera15a40/data/{main,tornei,fanta,albo,log}
    // (vedi _doc() in laurera15a40_11.html).
    match /clubs/{clubId}/data/{docId} {
      // Lettura pubblica: la app mostra i dati anche a chi non ha fatto login (modalità viewer).
      allow read: if true;

      // Scrittura solo da utente autenticato (solo l'admin conosce email/password)
      // e solo sui documenti effettivamente usati dall'app.
      allow write: if request.auth != null
                   && docId in ['main', 'tornei', 'fanta', 'albo', 'log'];
    }

    // Tutto il resto: negato di default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
